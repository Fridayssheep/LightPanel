# Copy this file to .env and fill the values you need.

# OpenAI-compatible chat completions endpoint. Required for /agent/chat.
# Examples:
# LLM_BASE_URL=https://api.openai.com/v1
# LLM_BASE_URL=https://api.deepseek.com
LLM_BASE_URL=
LLM_API_KEY=
LLM_MODEL=

# Runtime data paths.
OPS_AGENT_DATA_DIR=data
OPS_AGENT_HISTORY_FILE=data/incidents.json
OPS_AGENT_RUNTIME_SETTINGS_FILE=data/settings.json

# Log files are readable only under these roots.
OPS_AGENT_LOG_ROOTS=samples/logs

# Compose files are discovered only under these mapped project roots.
# Multiple roots can be separated by newlines in WebUI settings or commas here.
OPS_AGENT_PROJECT_ROOTS=samples

# Only dangerous operations, such as stopping containers, require approval.
OPS_AGENT_REQUIRE_DANGEROUS_APPROVAL=true

# Optional proxy values passed to docker CLI / docker compose processes inside
# the agent container. When using /var/run/docker.sock, registry pulls are often
# performed by the host Docker daemon, so Docker Desktop / daemon proxy settings
# may still be required.
OPS_AGENT_DOCKER_HTTP_PROXY=
OPS_AGENT_DOCKER_HTTPS_PROXY=
OPS_AGENT_DOCKER_NO_PROXY=localhost,127.0.0.1

# Optional external MCP stdio servers exposed to the AI agent.
# JSON object format:
# OPS_AGENT_EXTERNAL_MCP_SERVERS={"web":{"command":"uvx","args":["--from","mcp-server-fetch","mcp-server-fetch"],"description":"Read web tutorials"}}
OPS_AGENT_EXTERNAL_MCP_SERVERS=

# Disabled by default. When true, the built-in MCP server is exposed at /api/mcp
# through the Web API entrypoint. Only enable it on trusted networks.
OPS_AGENT_ENABLE_PUBLIC_MCP=false
